# Socket.IO server base URL (backend)
VITE_SOCKET_URL=http://localhost:3000

# REST API base URL (backend)
VITE_API_URL=http://localhost:3000

# Optional Socket.IO auth token for playlist client
VITE_PLAYLIST_SOCKET_TOKEN=changeme-playlist-socket-token
# Shared fallback token (if above is not set)
VITE_SOCKET_AUTH_TOKEN=changeme-shared-socket-token
